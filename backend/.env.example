# ============================================
# LLM Halüsinasyon Tespit Backend
# Ortam Değişkenleri Şablonu
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin:
#   cp .env.example .env

# --- Uygulama Ayarları ---
APP_NAME="LLM Halusinasyon Tespit Backend"
APP_VERSION="0.1.0"
DEBUG=True
LOG_LEVEL=INFO

# --- Sunucu Ayarları ---
HOST=0.0.0.0
PORT=8000

# --- Veritabanı ---
# SQLite (geliştirme için varsayılan)
DATABASE_URL=sqlite:///./llm_halusinasyon.db

# PostgreSQL'e geçiş için:
# DATABASE_URL=postgresql://user:password@localhost:5432/llm_halusinasyon

# --- Ollama Ayarları ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_REQUEST_TIMEOUT=180

# --- Pipeline Varsayılan Parametreleri ---
DEFAULT_TEMPERATURE=0.0
DEFAULT_SEED=42
DEFAULT_TOP_P=0.9
DEFAULT_MAX_TOKENS=512
DEFAULT_REPEAT_COUNT=3

# Pipeline çalıştırma sırasında hata yönetimi
MAX_RETRY_COUNT=2
RETRY_BACKOFF_SECONDS=5

# --- Veri Dosyası ---
QUESTIONS_JSON_PATH=./data/halusinasyon_test_sorulari.json

# --- CORS (Frontend için) ---
CORS_ORIGINS=*

# --- Test Edilecek Modeller ---
# Virgülle ayrılmış liste
DEFAULT_MODELS=mistral:7b,llama3.1:8b,qwen2.5:7b,ytagalar/trendyol-llm-7b-chat-dpo-v1.0-gguf
